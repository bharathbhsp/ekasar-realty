# Neon Postgres (required — SQLite does not work on Vercel serverless)
# Use the pooled URL for app runtime; for migrations use the non-pooling URL
# (Neon dashboard → Connection details → "Pooled" vs "Direct")
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Optional locally; on Vercel, trustHost handles the production URL automatically
AUTH_URL="http://localhost:3000"

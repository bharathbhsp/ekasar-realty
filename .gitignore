# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env & secrets (never commit — use .env.example as template)
.env
.env.*
!.env.example
!.env*.example
.envrc

# pulled from Vercel / hosting providers
.env.production.local
.env.development.local
.env.test.local
.env.vercel

# keys & certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_rsa.*
id_dsa
id_ed25519
*.secret

# cloud & service credentials
credentials.json
**/credentials.json
service-account*.json
**/service-account*.json
.secrets/
secrets/

# database (local SQLite and journals)
prisma/*.db
prisma/*.db-journal
prisma/dev.db
prisma/dev.db-journal
*.sqlite
*.sqlite3

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

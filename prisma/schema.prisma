generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Supabase Postgres: DATABASE_URL = Transaction pooler (6543), DIRECT_URL = direct (5432)
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          String    @default("USER")
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  posts         Post[]
}

model Post {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String
  body          String
  coverImageUrl String?
  visibility    String    @default("DRAFT")
  tags          String    @default("")
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  status      String
  location    String
  bhkTypes    String
  description String
  images      String   @default("[]")
  highlights  String   @default("[]")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  projectInterest String?
  message         String?
  source          String   @default("website")
  createdAt       DateTime @default(now())
}
